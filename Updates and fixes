="card-title">🇦🇺 Your Region</div></div><div class="tab-container" id="locationTabs"><div class="tab active" data-loc="tasmania">TAS</div><div class="tab" data-loc="victoria">VIC</div><div class="tab" data-loc="south-aus">SA</div><div class="tab" data-loc="west-aus">WA</div><div class="tab" data-loc="nsw">NSW</div></div><div class="data-grid"><div class="data-item"><div class="data-label">Chance tonight</div><div class="data-value" id="locationChance">--%</div></div><div class="data-item"><div class="data-label">Best time</div><div class="data-value" id="bestTimeLocal">10pm–2am</div></div></div><div class="tasmania-dropdown" id="tasmaniaDropdown"><div class="tasmania-dropdown-header" id="tasmaniaDropdownHeader"><span>📍 Tasmania Advantage ▼</span><span>✨</span></div><div class="tasmania-advantage-content" id="tasmaniaAdvantageContent"><div><strong>⚡ Prime location</strong><br><span id="advantageText">Closest to auroral oval</span></div><div><strong>📈 Visibility boost</strong><br><span id="boostText">+30% vs mainland</span></div><div style="background:rgba(0,255,170,0.1); padding:6px; border-radius:10px;"><strong>💡 Tip:</strong> <span id="tasmaniaTip">Check southern horizon after 10pm</span></div></div></div></div><div class="card detailed-card"><div class="card-header"><div class="card-title">📈 3‑Day Forecast</div></div><div style="display:flex; gap:8px; margin-bottom:10px;"><button class="interval-btn" data-interval="3h" id="interval3hBtn">3-Hour</button><button class="interval-btn" data-interval="daily" id="intervalDailyBtn">Daily</button></div><div class="forecast-chart-container" id="forecastChartContainer"></div><div class="data-grid"><div class="data-item"><div class="data-label">Today peak</div><div id="peakToday" class="data-value">--</div></div><div class="data-item"><div class="data-label">Tomorrow</div><div id="peakTomorrow" class="data-value">--</div></div></div></div></div><div class="sidebar detailed-card"><div class="card"><div class="card-header"><div class="card-title">⚠️ Aurora Alerts <span style="font-size:0.7rem;">(AI generated)</span></div></div><div id="alertsList" style="font-size:0.75rem;">No active alerts</div></div><div class="card"><div class="card-header"><div class="card-title">🤖 Agent Recommendations</div></div><div id="agentRecommendations" style="font-size:0.75rem;">Waiting for data...</div></div><div class="card"><div class="card-header"><div class="card-title">💡 Viewing Tips</div></div><div style="font-size:0.7rem;">📍 Dark sky, south view<br>🌙 New moon = best<br>⏰ 10pm–2am local<br>📷 Tripod & long exposure</div></div><div class="card"><div class="card-header"><div class="card-title">📡 Data Sources</div></div><div style="font-size:0.7rem;">Primary: BOM / NOAA fallback<br><span id="sourceLatency">--</span> ms latency<br><span id="agentStatus">🤖 Agent: Active</span></div></div></div></div></div>
<div class="footer"><div>Aurora Tracker • AI-Powered Monitoring Agent</div><div style="margin-top: 8px;">Jay Rowley © 2025 • PWA v2.0 • Agent v1.0</div><div style="margin-top: 6px; font-size: 0.7rem; opacity: 0.7;"><span id="locationNote">📍 Select region or use location</span></div></div>

<script type="module">
    // Import agent modules (ES modules now working)
    import { SpaceWeatherAgent } from './agent/spaceWeatherAgent.js';
    import { NotificationManager } from './notifications/manager.js';
    import { DataCache } from './services/dataCache.js';
    
    let auroraAgent = null;
    let notificationManager = null;
    let dataCache = null;
    let lastAgentResult = null;
    
    // DOM Elements
    const dashboard = document.getElementById('dashboardContent');
    const loadingDiv = document.getElementById('loading');
    const dataStatusSpan = document.getElementById('dataStatus');
    const kpSpan = document.getElementById('kpValue');
    const kpDesc = document.getElementById('kpDescription');
    const kpIndicator = document.getElementById('kpIndicator');
    const visibilitySpan = document.getElementById('visibilityChance');
    const stormSpan = document.getElementById('stormLevel');
    const moonPhaseSpan = document.getElementById('moonPhase');
    const moonDetailSpan = document.getElementById('moonDetail');
    const cloudSpan = document.getElementById('cloudCover');
    const viewingScoreSpan = document.getElementById('viewingScore');
    const viewingAdviceSpan = document.getElementById('viewingAdvice');
    const speedSpan = document.getElementById('speedValue');
    const bzSpan = document.getElementById('bzValue');
    const locationChanceSpan = document.getElementById('locationChance');
    const alertsDiv = document.getElementById('alertsList');
    const peakTodaySpan = document.getElementById('peakToday');
    const peakTomorrowSpan = document.getElementById('peakTomorrow');
    const advantageTextSpan = document.getElementById('advantageText');
    const boostTextSpan = document.getElementById('boostText');
    const tasmaniaTipSpan = document.getElementById('tasmaniaTip');
    const sourceLatencySpan = document.getElementById('sourceLatency');
    const agentSummarySpan = document.getElementById('agentSummary');
    const agentRecommendationsDiv = document.getElementById('agentRecommendations');
    const agentStatusSpan = document.getElementById('agentStatus');
    
    let currentData = null, forecastData = null;
    let selectedLocation = 'tasmania';
    let isUsingBOM = true;
    let userLat = null;
    let currentInterval = '3h';
    let refreshInterval = null;
    
    // NO DUPLICATE SCORING FUNCTION - agent is the ONLY source
    
    function getMoonPhase(date) {
        const knownNew = new Date(2024, 0, 11);
        const lunarCycle = 29.53058867;
        const daysSince = (date - knownNew) / (1000 * 60 * 60 * 24);
        const phase = (daysSince % lunarCycle) / lunarCycle;
        if (phase < 0.03 || phase > 0.97) return { name: '🌑 New', brightness: 0, desc: 'Excellent - dark' };
        if (phase < 0.22) return { name: '🌒 Waxing', brightness: 0.2, desc: 'Good' };
        if (phase < 0.28) return { name: '🌓 First Qtr', brightness: 0.5, desc: 'Moderate' };
        if (phase < 0.47) return { name: '🌔 Waxing Gibb', brightness: 0.7, desc: 'Bright' };
        if (phase < 0.53) return { name: '🌕 Full', brightness: 1.0, desc: 'Poor - very bright' };
        if (phase < 0.72) return { name: '🌖 Waning Gibb', brightness: 0.7, desc: 'Bright' };
        if (phase < 0.78) return { name: '🌗 Last Qtr', brightness: 0.5, desc: 'Moderate' };
        return { name: '🌘 Waning', brightness: 0.2, desc: 'Good' };
    }
    
    function estimateCloudCover() {
        const hour = new Date().getHours();
        let percent = 45;
        if (selectedLocation === 'tasmania') percent = 55 + Math.sin(hour * 0.5) * 15;
        else if (selectedLocation === 'victoria') percent = 48 + Math.cos(hour * 0.4) * 18;
        else if (selectedLocation === 'west-aus') percent = 35 + Math.random() * 25;
        else percent = 42 + Math.random() * 22;
        percent = Math.min(92, Math.max(8, percent));
        let coverage = percent < 25 ? 'Clear' : (percent < 55 ? 'Partly cloudy' : (percent < 80 ? 'Cloudy' : 'Overcast'));
        return { coverage: `${coverage} (${Math.round(percent)}%)`, percent };
    }
    
    // REMOVED calculateViewingScore - AGENT IS THE ONLY SOURCE
    
    async function fetchNOAAData() {
        const start = Date.now();
        try {
            const kpRes = await fetch('https://services.swpc.noaa.gov/products/noaa-planetary-k-index.json?t=' + Date.now());
            let kp = 3.2;
            if (kpRes.ok) { const kpData = await kpRes.json(); if (Array.isArray(kpData) && kpData.length > 1) { const last = kpData[kpData.length - 1]; kp = parseFloat(last[1]); if (isNaN(kp)) kp = 3.2; } }
            let bz = -2;
            const magRes = await fetch('https://services.swpc.noaa.gov/products/solar-wind/mag-2-hour.json?t=' + Date.now());
            if (magRes.ok) { const magData = await magRes.json(); if (Array.isArray(magData) && magData.length > 1) { const last = magData[magData.length - 1]; bz = parseFloat(last[3]) || -2; } }
            let speed = 400;
            const plasmaRes = await fetch('https://services.swpc.noaa.gov/products/solar-wind/plasma-2-hour.json?t=' + Date.now());
            if (plasmaRes.ok) { const plasmaData = await plasmaRes.json(); if (Array.isArray(plasmaData) && plasmaData.length > 1) { const last = plasmaData[plasmaData.length - 1]; speed = parseFloat(last[2]) || 400; } }
            const now = new Date();
            let fcList = [];
            for (let i = 1; i <= 12; i++) { let dt = new Date(); dt.setHours(now.getHours() + i * 3); let forecastKp = kp + Math.sin(i * 0.8) * 0.5; forecastKp = Math.min(9, Math.max(0, forecastKp)); fcList.push({ timestamp: dt, kp: forecastKp }); }
            const peakToday = Math.max(...fcList.slice(0, 4).map(f => f.kp), kp);
            const peakTomorrow = Math.max(...fcList.slice(4, 8).map(f => f.kp), peakToday);
            return { kp: Math.min(9, Math.max(0, kp)), solar: { speed: Math.round(speed), bz: parseFloat(bz.toFixed(1)) }, forecast: { allForecasts: fcList, peakToday, peakTomorrow }, source: 'NOAA', latency: Date.now() - start };
        } catch (e) { throw e; }
    }
    
    async function fetchData() {
        loadingDiv.style.display = 'block';
        dataStatusSpan.innerText = '🔄 FETCHING';
        dataStatusSpan.className = 'data-status status-loading';
        
        try {
            let data = await fetchNOAAData();
            currentData = data;
            forecastData = data.forecast;
            
            if (dataCache) {
                dataCache.saveAuroraData(currentData, forecastData);
            }
            
            sourceLatencySpan.innerText = data.latency + ' ms';
            dataStatusSpan.innerText = '✅ NOAA DATA';
            dataStatusSpan.className = 'data-status status-noaa';
            
            // Run agent evaluation (only on data fetch, not on every UI update cycle)
            await evaluateWithAgent();
            
            dashboard.style.display = 'block';
            showAlert('success', `Data updated in ${data.latency}ms`);
        } catch (err) {
            console.error(err);
            if (dataCache && dataCache.hasValidData()) {
                const cached = dataCache.getCachedAuroraData();
                currentData = cached.current;
                forecastData = cached.forecast;
                await evaluateWithAgent();
                dashboard.style.display = 'block';
                dataStatusSpan.innerText = '📦 CACHED';
                dataStatusSpan.className = 'data-status';
                showAlert('warning', 'Using cached data - NOAA unavailable');
            } else {
                currentData = { kp: 3.5, solar: { speed: 410, bz: -2.5 }, forecast: { peakToday: 4.0, peakTomorrow: 4.2, allForecasts: [] } };
                forecastData = currentData.forecast;
                for (let i = 1; i <= 8; i++) { let dt = new Date(); dt.setHours(dt.getHours() + i * 3); forecastData.allForecasts.push({ timestamp: dt, kp: 3.5 + Math.sin(i) * 0.4 }); }
                await evaluateWithAgent();
                dashboard.style.display = 'block';
                dataStatusSpan.innerText = '⚠️ ESTIMATED';
                dataStatusSpan.className = 'data-status status-loading';
                showAlert('warning', 'Using estimated data - NOAA unavailable');
            }
        } finally { 
            loadingDiv.style.display = 'none'; 
        }
    }
    
    // AGENT EVALUATION - runs only on data fetch (not on UI cycles)
    async function evaluateWithAgent() {
        if (!currentData || !auroraAgent) return;
        
        const moon = getMoonPhase(new Date());
        const cloud = estimateCloudCover();
        
        // Agent is the SINGLE source of truth for all decisions
        const agentResult = auroraAgent.evaluate(currentData, forecastData, {
            moonBrightness: moon.brightness,
            cloudPercent: cloud.percent,
            location: selectedLocation,
            timestamp: Date.now()
        });
        
        lastAgentResult = agentResult;
        
        // Update ALL UI elements from agent result (no duplicate calculations)
        updateUIFromAgent(agentResult, moon, cloud);
        
        // Send notification if needed (only after user has granted permission via button)
        if (agentResult.shouldNotify && notificationManager && notificationManager.permissionGranted) {
            const notified = notificationManager.sendAuroraAlert(agentResult, selectedLocation, () => {
                // Mark notification sent in agent state
                auroraAgent.markNotificationSent();
            });
            if (notified) {
                dataStatusSpan.classList.add('status-agent');
                setTimeout(() => dataStatusSpan.classList.remove('status-agent'), 2000);
            }
        }
    }
    
    // Single UI update function - reads ONLY from agent result
    function updateUIFromAgent(agentResult, moon, cloud) {
        const kp = currentData.kp;
        const bz = currentData.solar.bz;
        
        // Use agent's score (THE ONE TRUE SCORE)
        viewingScoreSpan.innerText = agentResult.score + '/100';
        
        // Use agent's summary and recommendations
        agentSummarySpan.innerHTML = `🤖 ${agentResult.summary}`;
        
        if (agentResult.recommendations && agentResult.recommendations.length) {
            agentRecommendationsDiv.innerHTML = agentResult.recommendations.map(r => 
                `<div class="agent-recommendation">💡 ${r}</div>`
            ).join('');
        } else {
            agentRecommendationsDiv.innerHTML = '<div>No active recommendations. Keep monitoring.</div>';
        }
        
        // Use agent's alerts with severity-based styling
        if (agentResult.alerts && agentResult.alerts.length) {
            alertsDiv.innerHTML = agentResult.alerts.map(alert => {
                let severityClass = '';
                if (alert.severity === 'critical') severityClass = 'alert-critical';
                else if (alert.severity === 'high') severityClass = 'alert-high';
                else if (alert.severity === 'medium') severityClass = 'alert-medium';
                return `<div class="${severityClass}" style="padding:8px;border-radius:10px;margin:6px 0;">
                            <strong>${alert.title}</strong><br>
                            <span style="font-size:0.7rem;">${alert.message}</span>
                        </div>`;
            }).join('');
        } else {
            alertsDiv.innerHTML = '✅ No active alerts from agent';
        }
        
        // Update viewing advice based on agent's score
        if (agentResult.score >= 70) viewingAdviceSpan.innerText = '🔥 Excellent! Go outside!';
        else if (agentResult.score >= 50) viewingAdviceSpan.innerText = '👍 Good chance - find dark skies';
        else if (agentResult.score >= 30) viewingAdviceSpan.innerText = '⚠️ Marginal - check horizon';
        else viewingAdviceSpan.innerText = '❌ Poor - try another night';
        
        // Standard UI updates (display data, not decisions)
        kpSpan.innerText = kp.toFixed(1);
        kpDesc.innerText = kp >= 6 ? '⚡ Storm - excellent chance!' : (kp >= 4 ? '✨ Active - keep watching' : '🌙 Quiet - low probability');
        const percentPos = (kp / 9) * 100;
        kpIndicator.style.left = `${Math.min(100, Math.max(0, percentPos))}%`;
        stormSpan.innerText = kp >= 7 ? 'Severe' : (kp >= 5 ? 'Moderate' : (kp >= 4 ? 'Active' : 'Quiet'));
        moonPhaseSpan.innerText = moon.name;
        moonDetailSpan.innerText = moon.desc;
        cloudSpan.innerText = cloud.coverage;
        
        // Location-based chance (still needed for regional display)
        let baseChance = Math.min(90, Math.max(0, (kp - 3) * 22));
        if (selectedLocation === 'tasmania') baseChance = Math.min(95, baseChance * 1.35);
        else if (selectedLocation === 'victoria') baseChance = Math.min(88, baseChance * 1.1);
        const finalChance = Math.round(baseChance);
        locationChanceSpan.innerText = finalChance + '%';
        visibilitySpan.innerText = finalChance + '%';
        
        speedSpan.innerText = currentData.solar.speed;
        bzSpan.innerText = currentData.solar.bz.toFixed(1);
        
        if (forecastData) { 
            peakTodaySpan.innerText = forecastData.peakToday?.toFixed(1) + ' K'; 
            peakTomorrowSpan.innerText = forecastData.peakTomorrow?.toFixed(1) + ' K'; 
            updateForecastChart(); 
        }
        
        const boost = Math.min(65, 30 + Math.floor(kp * 4));
        advantageTextSpan.innerText = `Tasmania closest to oval - K${kp.toFixed(1)} gives ${boost}% better odds`;
        boostTextSpan.innerText = `+${boost}% vs mainland`;
        tasmaniaTipSpan.innerText = kp >= 5 ? 'Head to southern coast after 10pm!' : 'Check again when K-index rises';
    }
    
    function updateForecastChart() {
        const container = document.getElementById('forecastChartContainer');
        if (!container) return;
        container.innerHTML = '';
        let list = [];
        if (currentInterval === 'daily') {
            list = [ { label: 'Today', kp: forecastData?.peakToday || 3.5 }, { label: 'Tomorrow', kp: forecastData?.peakTomorrow || 4.0 }, { label: 'Day 3', kp: (forecastData?.peakTomorrow || 4.0) - 0.3 } ];
        } else {
            if (forecastData?.allForecasts && forecastData.allForecasts.length) list = forecastData.allForecasts.slice(0, 8).map(f => ({ label: f.timestamp.getHours() + 'h', kp: f.kp }));
            else for (let i = 1; i <= 8; i++) list.push({ label: (new Date().getHours() + i * 3) % 24 + 'h', kp: 3.5 });
        }
        list.forEach(item => { const div = document.createElement('div'); div.className = 'forecast-bar-container'; const h = Math.min(110, (item.kp / 9) * 110); div.innerHTML = `<div class="forecast-bar" style="height:${h}px;"></div><div style="font-size:9px;margin-top:4px;">${item.label}</div><div style="font-size:9px;">${item.kp.toFixed(1)}</div>`; container.appendChild(div); });
    }
    
    function selectLocation(loc) { 
        selectedLocation = loc; 
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active')); 
        document.querySelector(`.tab[data-loc="${loc}"]`)?.classList.add('active'); 
        const tasDropdown = document.getElementById('tasmaniaDropdown'); 
        if (loc === 'tasmania') tasDropdown.style.display = 'block'; 
        else tasDropdown.style.display = 'none'; 
        // Re-evaluate with new location
        if (currentData) evaluateWithAgent();
    }
    
    function getLocation() { 
        if (navigator.geolocation) { 
            navigator.geolocation.getCurrentPosition(pos => { 
                userLat = pos.coords.latitude; 
                let closest = 'victoria'; 
                if (userLat < -40) closest = 'tasmania'; 
                else if (userLat < -35) closest = 'victoria'; 
                else if (userLat < -32) closest = 'south-aus'; 
                else closest = 'nsw'; 
                selectLocation(closest); 
                document.getElementById('locationNote').innerText = `📍 Set to ${closest}`; 
            }, () => { 
                alert('Location permission denied'); 
            }); 
        } 
    }
    
    // This MUST be called from user gesture (button click)
    async function enableNotifications() {
        if (notificationManager) {
            const granted = await notificationManager.requestPermission();
            if (granted) {
                showAlert('success', '🔔 Notifications enabled! You will receive aurora alerts.');
                // Test notification
                notificationManager.sendNotification('Aurora Tracker', 'Notifications are now active!');
            } else {
                showAlert('warning', 'Notification permission denied. Check browser settings.');
            }
        } else {
            showAlert('warning', 'Notification manager not available.');
        }
    }
    
    function showAlert(type, msg) {
        const alertDiv = document.getElementById('dataAlert');
        alertDiv.innerHTML = msg;
        alertDiv.style.display = 'block';
        alertDiv.style.background = type === 'success' ? 'rgba(0,255,170,0.15)' : (type === 'warning' ? 'rgba(255,140,66,0.2)' : 'rgba(100,100,255,0.15)');
        alertDiv.style.border = '1px solid var(--bom-orange)';
        setTimeout(() => { alertDiv.style.display = 'none'; }, 3500);
    }
    
    function startAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        // Note: This only runs while tab is open
        // For true background agent, would need Service Worker periodic sync
        refreshInterval = setInterval(() => {
            console.log('🤖 Agent auto-refresh triggered');
            fetchData();
        }, 10 * 60 * 1000);
    }
    
    // Initialize everything
    async function init() {
        // Initialize modules
        auroraAgent = new SpaceWeatherAgent();
        notificationManager = new NotificationManager(); // Does NOT request permission
        dataCache = new DataCache();
        
        agentStatusSpan.innerText = '🤖 Agent: Active';
        
        // Load cached data if available
        const cached = dataCache.getCachedAuroraData();
        if (cached.current && cached.forecast) {
            currentData = cached.current;
            forecastData = cached.forecast;
            await evaluateWithAgent();
            dashboard.style.display = 'block';
            showAlert('info', '📦 Loaded cached data while fetching latest...');
        }
        
        await fetchData();
        startAutoRefresh();
        
        setTimeout(() => {
            if (auroraAgent) {
                dataStatusSpan.innerHTML = '🤖 AGENT ACTIVE';
                dataStatusSpan.classList.add('status-agent');
            }
        }, 1000);
    }
    
    // Set up event listeners (these remain the same as before)
    document.getElementById('simpleViewBtn').onclick = () => { document.body.classList.add('simple-view'); document.getElementById('simpleViewBtn').classList.add('active'); document.getElementById('detailedViewBtn').classList.remove('active'); };
    document.getElementById('detailedViewBtn').onclick = () => { document.body.classList.remove('simple-view'); document.getElementById('detailedViewBtn').classList.add('active'); document.getElementById('simpleViewBtn').classList.remove('active'); };
    document.getElementById('interval3hBtn').onclick = () => { currentInterval = '3h'; document.getElementById('interval3hBtn').classList.add('active'); document.getElementById('intervalDailyBtn').classList.remove('active'); updateForecastChart(); };
    document.getElementById('intervalDailyBtn').onclick = () => { currentInterval = 'daily'; document.getElementById('intervalDailyBtn').classList.add('active'); document.getElementById('interval3hBtn').classList.remove('active'); updateForecastChart(); };
    document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => selectLocation(t.dataset.loc)));
    document.getElementById('fetchBtn').onclick = () => fetchData();
    document.getElementById('locationBtn').onclick = () => getLocation();
    document.getElementById('notifyBtn').onclick = () => enableNotifications(); // User gesture!
    document.getElementById('useBOMToggle').onchange = () => fetchData();
    document.getElementById('tasmaniaDropdownHeader').onclick = () => { document.getElementById('tasmaniaAdvantageContent').classList.toggle('open'); };
    
    // Starfield
    const starsDiv = document.getElementById('stars');
    for (let i = 0; i < 120; i++) { 
        const star = document.createElement('div'); 
        star.className = 'star' + (Math.random() > 0.7 ? ' twinkle' : ''); 
        star.style.left = Math.random() * 100 + '%'; 
        star.style.top = Math.random() * 100 + '%'; 
        star.style.width = (Math.random() * 2 + 1) + 'px'; 
        star.style.height = star.style.width; 
        star.style.opacity = 0.3 + Math.random() * 0.6; 
        starsDiv.appendChild(star); 
    }
    
    // Start the app
    init();
</script>
</body>
